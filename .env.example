# ============================================
# STRAPI PRODUCTION ENVIRONMENT CONFIGURATION
# Mehmet Eren Özden - Backend API
# ============================================

# -------------------- SERVER --------------------
HOST=0.0.0.0
PORT=1338

# API Public URL (API subdomaini)
PUBLIC_URL=https://api.mehmeterenozden.com

# Nginx/Cloudflare arkasında çalışıyorsanız true olmalı
IS_PROXIED=true

# Cron Jobs (opsiyonel zamanlanmış görevler için)
CRON_ENABLED=false

# -------------------- ADMIN PANEL --------------------
# Admin Panel URL (Yönetim paneli subdomaini - sondaki /admin OLMADAN)
ADMIN_URL=https://yonetimpaneli.mehmeterenozden.com

# Admin panelini bu instance'dan sunmak için true
SERVE_ADMIN=true

# Admin JWT Token süresi (7d = 7 gün)
ADMIN_JWT_EXPIRES_IN=7d

# Şifre sıfırlama e-posta ayarları
ADMIN_FORGOT_PASSWORD_FROM=no-reply@mehmeterenozden.com
ADMIN_FORGOT_PASSWORD_REPLY_TO=info@mehmeterenozden.com

# -------------------- CORS --------------------
# İzin verilen originler (virgülle ayrılmış)
CORS_ORIGINS=https://mehmeterenozden.com,https://www.mehmeterenozden.com,https://api.mehmeterenozden.com,https://yonetimpaneli.mehmeterenozden.com

# -------------------- SECURITY SECRETS --------------------
# ÖNEMLİ: Aşağıdaki değerleri production için benzersiz ve güvenli değerlerle değiştirin!
# Oluşturmak için: openssl rand -base64 32

APP_KEYS="PRODUCTION_KEY_1_REPLACE_ME,PRODUCTION_KEY_2_REPLACE_ME"
API_TOKEN_SALT=REPLACE_WITH_SECURE_RANDOM_STRING
ADMIN_JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
TRANSFER_TOKEN_SALT=REPLACE_WITH_SECURE_RANDOM_STRING
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
ENCRYPTION_KEY=REPLACE_WITH_SECURE_RANDOM_STRING

# -------------------- DATABASE --------------------
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=erenozden-website
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
DATABASE_SSL=false

# Production'da SSL bağlantısı için:
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# -------------------- OPTIONAL: PRODUCTION FLAGS --------------------
# Strapi NPS ve EE promosyon bildirimlerini kapatır
FLAG_NPS=false
FLAG_PROMOTE_EE=false

# -------------------- NODE ENVIRONMENT --------------------
NODE_ENV=production
